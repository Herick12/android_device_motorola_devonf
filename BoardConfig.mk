TARGET_NO_RECOVERY := false
BOARD_USES_RECOVERY_AS_BOOT := true
BOARD_BUILD_SYSTEM_ROOT_IMAGE := false
BOARD_MOVE_RECOVERY_RESOURCES_TO_VENDOR_BOOT := false

DEVICE_PATH := device/motorola/devonf
TARGET_BOARD_PLATFORM := mt6855
TARGET_ARCH := arm64
TARGET_ARCH_VARIANT := armv8-a
TARGET_CPU_ABI := arm64-v8a

BOARD_BOOTIMG_HEADER_VERSION := 4
BOARD_MKBOOTIMG_ARGS := --header_version 4

BOARD_KERNEL_BASE := 0x40078000
BOARD_KERNEL_PAGESIZE := 4096
BOARD_KERNEL_IMAGE_NAME := Image.gz-dtb
BOARD_KERNEL_CMDLINE := androidboot.hardware=mt6855 androidboot.selinux=permissive androidboot.slot_suffix=_a loop.max_part=7

TARGET_PREBUILT_KERNEL := $(DEVICE_PATH)/prebuilt/kernel

BOARD_BOOTIMAGE_PARTITION_SIZE := 134217728
BOARD_SUPER_PARTITION_SIZE := 9126805504
BOARD_SUPER_PARTITION_PARTITION_LIST := system system_ext vendor product

TARGET_COPY_OUT_VENDOR := vendor
TARGET_COPY_OUT_PRODUCT := product
TARGET_COPY_OUT_SYSTEM_EXT := system_ext

BOARD_PRODUCTIMAGE_FILE_SYSTEM_TYPE := ext4
BOARD_SYSTEM_EXTIMAGE_FILE_SYSTEM_TYPE := ext4
BOARD_VENDORIMAGE_FILE_SYSTEM_TYPE := ext4

TW_THEME := portrait_hdpi
TW_EXTRA_LANGUAGES := true
TW_HAS_MTP := true
TW_INCLUDE_FASTBOOTD := true
TW_INCLUDE_CRYPTO := true
TW_INCLUDE_NTFS := true
TW_INCLUDE_REPACKTOOLS := true
TW_INCLUDE_RECOVERY_FSTAB := true
TARGET_RECOVERY_FSTAB := $(DEVICE_PATH)/recovery.fstab

ALLOW_MISSING_DEPENDENCIES := true
BUILD_BROKEN_MISSING_REQUIRED_MODULES := true
