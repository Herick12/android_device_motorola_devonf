/dev/block/bootdevice/by-name/boot     /boot       emmc    defaults
/dev/block/bootdevice/by-name/recovery /recovery   emmc    defaults
/dev/block/bootdevice/by-name/system   /system     ext4    ro,barrier=1
/dev/block/bootdevice/by-name/vendor   /vendor     ext4    ro,barrier=1
/dev/block/bootdevice/by-name/data     /data       ext4    noatime,nosuid,nodev,discard
